# Remote Sensor Upload Client Configuration
# Copy this file and set your environment-specific values

# Server Configuration
SERVER_URL=http://maintenance-server.local:5001
# For production: https://maintenance-server.example.com

# Neon PostgreSQL Database Configuration
# Get your connection string from: https://console.neon.tech/app/projects
DATABASE_URL=postgresql://user:password@your-project.neon.tech/neondb

# Authentication (provided by system administrator)
API_KEY=sk_prod_7f3b8e2a9c1d4f6e5a2b9c8d7e1f3a5b
SENSOR_ID=sensor-001

# Upload Schedule
UPLOAD_INTERVAL_HOURS=2
UPLOAD_START_HOUR=6  # Start at 6 AM local time

# Retry Configuration
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5  # Initial backoff, then exponential

# Logging
LOG_LEVEL=INFO
LOG_FILE=upload_client.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=3

# Local Paths
LOCAL_DATA_DIR=./sensor_data
UPLOAD_VALIDATION=true

# Timeouts (seconds)
CONNECTION_TIMEOUT=30
READ_TIMEOUT=60

# Advanced
USE_COMPRESSION=true
VERIFY_SSL=true
PROXY_URL=  # Leave empty if no proxy

# Notifications (optional)
ALERT_EMAIL=admin@example.com
SLACK_WEBHOOK=  # Optional: for Slack alerts
